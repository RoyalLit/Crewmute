# Backend API base URL (required for production)
EXPO_PUBLIC_API_URL=http://localhost:5001/api/v1

# Google Places API key (optional — falls back to Nominatim)
EXPO_PUBLIC_GOOGLE_PLACES_KEY=

# Sentry DSN for error tracking (optional — leave empty to disable)
# Get your DSN at https://sentry.io
EXPO_PUBLIC_SENTRY_DSN=
