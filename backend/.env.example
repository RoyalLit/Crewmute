# Backend Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# All required variables must be set or the server will refuse to start.
# See docs/ARCHITECTURE.md §8.1 for full reference.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Required: MongoDB Atlas connection string (or local: mongodb://localhost:27017/crewmute)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/crewmute?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Required: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_with_64_char_random_hex_string
REFRESH_TOKEN_SECRET=replace_with_different_64_char_random_hex_string

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Required for OTP email delivery (auth feature)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=re_your_resend_api_key_here

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Required for profile photo and student ID uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Mobile app URL — use * in development, restrict in production
CLIENT_URL=*

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Set to false to disable cron jobs on non-primary instances (for horizontal scaling)
CRON_ENABLED=true

# ─── Sentry (Error Tracking) ──────────────────────────────────────────────────
# Optional: Set DSN to enable Sentry error tracking. Leave empty to disable.
# Get your DSN at https://sentry.io
SENTRY_DSN=
